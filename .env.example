# Copy to .env and fill in your values (never commit .env)
# Get a key: https://aistudio.google.com/apikey

GEMINI_API_KEY=

# Optional: local model path (default serves from public/)
CUSTOM_MODEL_PATH=/models/breed_classifier
USE_CUSTOM_MODEL=true
MODEL_CONFIDENCE_THRESHOLD=60
FALLBACK_TO_GEMINI=true

# Optional: allow a custom dev tunnel host (e.g. ngrok)
# VITE_ALLOWED_HOST=your-subdomain.ngrok-free.dev
